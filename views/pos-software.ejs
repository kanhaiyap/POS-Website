<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { seo }) %>
</head>
<body>
  <%- include('partials/header') %>

  <main>

    <!-- ===== HERO ===== -->
    <section class="bm-hero">
      <div class="bm-hero-inner">
        <h1 class="bm-hero-title">Run Your Restaurant Smarter</h1>
        <p class="bm-hero-subtitle">Bhojan Mitra is an intelligent AI + IoT POS product that simplifies restaurant operations by unifying billing, kitchen workflows, inventory tracking, and actionable insights in one system.</p>
        <a href="/contact" class="bm-btn-primary">Get started</a>
      </div>
    </section>

    <!-- ===== FEATURES ===== -->
    <section class="bm-features" id="features">
      <div class="bm-features-inner">

        <div class="bm-badge">Bhojan Mitra AI + IoT POS</div>

        <!-- Feature 1 -->
        <div class="bm-feature-row">
          <div class="bm-feature-text">
            <h3 class="bm-feature-title">Kitchen Display Integration</h3>
            <p class="bm-feature-desc">Orders are routed to the correct station with color-coded priority and prep timers. Our intelligent routing system ensures efficient order flow, while color-coded priorities help your team address urgent orders quickly. Prep timers offer real-time feedback, enabling proactive intervention. Your feedback during pilot runs will help us optimize these features.</p>
          </div>
          <div class="bm-feature-img">
            <img src="/images/illus-kitchen.png" alt="Kitchen Display Integration" width="340" height="260">
          </div>
        </div>

        <!-- Feature 2 -->
        <div class="bm-feature-row bm-feature-row--reverse">
          <div class="bm-feature-img">
            <img src="/images/illus-dashboard.png" alt="Table & Order Management" width="340" height="260">
          </div>
          <div class="bm-feature-text">
            <h3 class="bm-feature-title">Table &amp; Order Management</h3>
            <p class="bm-feature-desc">We're working with our partners to improve key restaurant features. This includes voice-based table assignment to streamline seating. We are also refining split bill options and mid-service modifications to enhance the dining experience. These improvements aim to create a smoother workflow for restaurant staff.</p>
          </div>
        </div>

        <!-- Feature 3 -->
        <div class="bm-feature-row">
          <div class="bm-feature-text">
            <h3 class="bm-feature-title">Online &amp; Delivery Sync</h3>
            <p class="bm-feature-desc">Streamline your delivery process by consolidating partners and in-house orders into a single platform. Use voice confirmations to ensure accuracy and reduce mismatched tickets. Our system automatically verifies order details, minimizing errors and improving efficiency. This leads to faster delivery times and happier customers.</p>
          </div>
          <div class="bm-feature-img">
            <img src="/images/illus-pos-terminal.png" alt="Online & Delivery Sync" width="340" height="260">
          </div>
        </div>

        <!-- Feature 4 -->
        <div class="bm-feature-row bm-feature-row--reverse">
          <div class="bm-feature-img">
            <img src="/images/illus-voice.png" alt="Staff Productivity" width="340" height="260">
          </div>
          <div class="bm-feature-text">
            <h3 class="bm-feature-title">Staff Productivity</h3>
            <p class="bm-feature-desc">Use voice commands to quickly access voids, comps, shift reports, and inventory pulls. Our voice-activated system allows staff to stay on the floor while performing essential tasks. This reduces time spent away from customers and improves overall efficiency.</p>
          </div>
        </div>

        <!-- Feature 5 -->
        <div class="bm-feature-row">
          <div class="bm-feature-text">
            <h3 class="bm-feature-title">Billing &amp; Invoicing</h3>
            <p class="bm-feature-desc">Create GST-compliant invoices effortlessly and accept all payment methods. Our system simplifies financial management, providing accurate records and streamlined transactions. Focus on serving your customers, while we handle the complexities of payments.</p>
          </div>
          <div class="bm-feature-img">
            <img src="/images/illus-analytics.png" alt="Billing & Invoicing" width="340" height="260">
          </div>
        </div>

      </div>
    </section>

    <!-- ===== FAQ ===== -->
    <section class="bm-faq">
      <div class="bm-faq-inner">
        <span class="bm-faq-eyebrow">FAQ</span>
        <h2 class="bm-faq-title">Questions <span class="bm-faq-muted">Operators Ask Most</span></h2>

        <div class="bm-faq-list">

          <details class="bm-faq-item bm-faq-item--open">
            <summary class="bm-faq-question">
              What makes Bhojan Mitra different from other POS systems?
              <span class="bm-faq-icon"></span>
            </summary>
            <p class="bm-faq-answer">Bhojan Mitra is voice-first. Orders can be spoken in multiple Indian languages, modifiers are captured automatically, and IoT routing sends tickets to the right kitchen station without manual steps.</p>
          </details>

          <details class="bm-faq-item">
            <summary class="bm-faq-question">
              Can Bhojan Mitra replace my existing POS machine?
              <span class="bm-faq-icon"></span>
            </summary>
            <p class="bm-faq-answer">Yes. Bhojan Mitra runs on browsers, tablets, and our dedicated POS machine. We map printers and kitchen displays so you can migrate without downtime.</p>
          </details>

          <details class="bm-faq-item">
            <summary class="bm-faq-question">
              How long does pilot onboarding take?
              <span class="bm-faq-icon"></span>
            </summary>
            <p class="bm-faq-answer">Most pilot restaurants are up and running within 2–3 days. We handle setup, menu import, and staff training as part of the onboarding package.</p>
          </details>

          <details class="bm-faq-item">
            <summary class="bm-faq-question">
              Does the POS work if the internet drops?
              <span class="bm-faq-icon"></span>
            </summary>
            <p class="bm-faq-answer">Offline fallback mode keeps billing and order capture running locally. Orders sync automatically when connectivity is restored.</p>
          </details>

        </div>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="bm-cta">
      <div class="bm-cta-inner">
        <h2 class="bm-cta-title">See <span class="bm-cta-highlight">Bhojan Mitra</span> in Action</h2>
        <p class="bm-cta-sub">Join the pilot to experience voice ordering, IoT routing, and analytics tailored to your restaurant before our public launch.</p>
        <a href="/contact" class="bm-btn-primary">Get Started</a>
      </div>
    </section>

  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
