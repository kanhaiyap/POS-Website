<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { seo }) %>
</head>
<body>
  <%- include('partials/header') %>

  <main>

    <!-- ===== PRICING HERO ===== -->
    <section class="pricing-hero-section">
      <div class="container">
        <div class="pricing-hero-inner">
          <h1 class="pricing-hero-title">Simple, Transparent Pricing &mdash; For Every Restaurant</h1>
          <p class="pricing-hero-subtitle">We designed Bhojan Mitra pricing to be clear, fair, and tied to real value &mdash; so you only pay for what grows your business.</p>
        </div>
      </div>
    </section>

    <!-- ===== PLANS ===== -->
    <section class="pricing-section" id="plans">
      <div class="container">
        <div class="pricing-header">
          <span class="fig-badge">Founding Plans</span>
          <h2 class="fig-heading-2"><span class="fig-gradient-text">Reserve</span> Your Bhojan Mitra Bundle</h2>
          <p class="fig-subheading">Founding partners receive lifetime discounts, roadmap input, and white-glove onboarding</p>
        </div>

        <div class="pricing-grid">

          <!-- Simple Billing -->
          <div class="price-card price-card--bordered">
            <div class="price-card-badge">Simple Billing</div>
            <div class="price-card-body">
              <h3 class="price-card-name">Simple Billing</h3>
              <div class="price-amount-row">
                <span class="price-amount price-amount--dark">&#8377; 250/</span>
                <span class="price-period">Month</span>
              </div>
              <p class="price-desc">Essential billing tools for small restaurants</p>
            </div>
            <ul class="price-features">
              <li>
                <img src="/images/icon-check-green.svg" alt="&#10003;" width="26" height="26">
                Core billing &amp; invoicing
              </li>
              <li>
                <img src="/images/icon-check-green.svg" alt="&#10003;" width="26" height="26">
                Order capture (manual &amp; QR)
              </li>
              <li>
                <img src="/images/icon-check-green.svg" alt="&#10003;" width="26" height="26">
                Cloud backups &amp; updates
              </li>
              <li>
                <img src="/images/icon-check-green.svg" alt="&#10003;" width="26" height="26">
                Email support
              </li>
              <li>
                <img src="/images/icon-check-green.svg" alt="&#10003;" width="26" height="26">
                Founding partner discount locked for life
              </li>
            </ul>
            <a href="https://billing.aarohitavigyan.com/" target="_blank" rel="noopener" class="btn-figma-primary price-btn">Reserve &#8377;250 plans</a>
          </div>

          <!-- Analytics + QR (Most Popular) -->
          <div class="price-card">
            <div class="price-card-badge price-card-badge--popular">Most Popular</div>
            <div class="price-card-body">
              <h3 class="price-card-name">Analytics + QR</h3>
              <div class="price-amount-row">
                <span class="price-amount price-amount--orange">&#8377; 500/</span>
                <span class="price-period">Month</span>
              </div>
              <p class="price-desc">Advanced insights for scaling operations</p>
            </div>
            <ul class="price-features">
              <li>
                <img src="/images/icon-check-orange.svg" alt="&#10003;" width="26" height="26">
                Advanced sales &amp; staff analytics
              </li>
              <li>
                <img src="/images/icon-check-orange.svg" alt="&#10003;" width="26" height="26">
                QR menu builder &amp; ordering flow
              </li>
              <li>
                <img src="/images/icon-check-orange.svg" alt="&#10003;" width="26" height="26">
                Live dashboards &amp; custom reports
              </li>
              <li>
                <img src="/images/icon-check-orange.svg" alt="&#10003;" width="26" height="26">
                Priority email support
              </li>
              <li>
                <img src="/images/icon-check-orange.svg" alt="&#10003;" width="26" height="26">
                Roadmap workshops with our team
              </li>
            </ul>
            <a href="https://billing.aarohitavigyan.com/" target="_blank" rel="noopener" class="btn-figma-primary price-btn">Reserve &#8377;500 plans</a>
          </div>

          <!-- Voice Ordering -->
          <div class="price-card price-card--bordered">
            <div class="price-card-badge">Voice Ordering</div>
            <div class="price-card-body">
              <h3 class="price-card-name">Voice Ordering</h3>
              <div class="price-amount-row">
                <span class="price-amount price-amount--dark">&#8377; 5,000/</span>
                <span class="price-period">Month</span>
              </div>
              <p class="price-desc">Full AI-powered voice ordering system</p>
            </div>
            <ul class="price-features">
              <li>
                <img src="/images/icon-check-green.svg" alt="&#10003;" width="26" height="26">
                Full AI voice ordering (multilingual)
              </li>
              <li>
                <img src="/images/icon-check-green.svg" alt="&#10003;" width="26" height="26">
                IoT kitchen routing &amp; automation
              </li>
              <li>
                <img src="/images/icon-check-green.svg" alt="&#10003;" width="26" height="26">
                Priority onboarding &amp; training
              </li>
              <li>
                <img src="/images/icon-check-green.svg" alt="&#10003;" width="26" height="26">
                Dedicated founder support 24/7
              </li>
              <li>
                <img src="/images/icon-check-green.svg" alt="&#10003;" width="26" height="26">
                Hardware credits for your printers
              </li>
            </ul>
            <a href="https://billing.aarohitavigyan.com/" target="_blank" rel="noopener" class="btn-figma-primary price-btn">Reserve &#8377;5,000 plans</a>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="cta-home">
      <div class="container">
        <div class="cta-home-inner">
          <h2 class="cta-home-title">See Bhojan Mitra <span class="fig-gradient-text">in Action</span></h2>
          <p class="cta-home-desc">Join the pilot to experience voice ordering, IoT routing, and analytics tailored to your restaurant before our public launch.</p>
          <a href="/contact" class="btn-figma-primary">Get Started</a>
        </div>
      </div>
    </section>

  </main>

  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>
</body>
</html>
