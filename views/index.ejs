<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { seo }) %>
</head>
<body>
    <%- include('partials/header') %>

    <main>

        <!-- ===== HERO (Intro) ===== -->
        <section class="hero-intro">
            <div class="hero-intro-inner">

                <!-- Animated headline row -->
                <div class="hero-headline-row">
                    <div class="hero-word-clip" aria-live="polite" aria-label="AI-Powered POS for">
                        <div class="hero-word-track" id="heroWordTrack">
                            <span class="hero-word hero-word--serif">AI-Powered</span>
                            <span class="hero-word hero-word--inria">IoT Integration</span>
                            <span class="hero-word hero-word--inria">Voice ordering</span>
                            <span class="hero-word hero-word--serif">Multilingual</span>
                        </div>
                    </div>
                    <span class="hero-pos-for">POS for</span>
                </div>

                <h1 class="hero-main-title">Smarter Restaurants</h1>

                <p class="hero-subtitle">Eliminate manual data entry. Multilingual AI ordering that speaks your language and automates your kitchen operations.</p>

                <!-- Feature tags -->
                <div class="hero-tags">
                    <span class="hero-tag">
                        <img src="/images/icon-microphone.svg" alt="" width="24" height="24" aria-hidden="true">
                        Voice First AI
                    </span>
                    <span class="hero-tag">
                        <img src="/images/icon-globe.svg" alt="" width="24" height="24" aria-hidden="true">
                        Multilingual
                    </span>
                    <span class="hero-tag">
                        <img src="/images/icon-lightning.svg" alt="" width="24" height="24" aria-hidden="true">
                        IoT Integrated
                    </span>
                </div>

                <div class="hero-cta">
                    <a href="/contact" class="btn-figma-primary">Book a Demo</a>
                </div>
            </div>
        </section>

        <!-- ===== PRODUCT FEATURES ===== -->
        <section class="product-features" id="features">
            <div class="pf-header">
                <span class="fig-badge">Introducing Bhojan Mitra</span>
                <h2 class="fig-heading-2">One Platform, <span class="fig-muted">Everything You Need</span></h2>
                <p class="fig-subheading">We're building these Bhojan Mitra components hand-in-hand with early partners</p>
            </div>

            <!-- Feature showcase -->
            <div class="pf-screenshot-wrap">
                <div class="showcase-wrap">

                    <!-- Center image -->
                    <div class="sc-center">
                        <img src="/images/illus-dashboard.png" alt="Bhojan Mitra POS dashboard" class="sc-center-img">
                    </div>

                    <!-- Scrolling cards -->
                    <div class="sc-card sc-card--mid-left" style="--delay:-18s">
                        <div class="sc-icon" style="background:#f0fdf4;">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                        </div>
                        <span class="sc-label">Billing &amp;<br>Invoicing</span>
                    </div>

                    <div class="sc-card sc-card--mid-left" style="--delay:-16.5s">
                        <div class="sc-icon" style="background:#fdf4ff;">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#d946ef" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/><path d="M19 10v2a7 7 0 01-14 0v-2M12 19v4M8 23h8"/></svg>
                        </div>
                        <span class="sc-label">Voice<br>Ordering</span>
                    </div>

                    <div class="sc-card sc-card--mid-left" style="--delay:-15s">
                        <div class="sc-icon" style="background:#eef2ff;">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                        </div>
                        <span class="sc-label">Analytics &amp;<br>Insights</span>
                    </div>

                    <div class="sc-card sc-card--mid-left" style="--delay:-13.5s">
                        <div class="sc-icon" style="background:#fff7ed;">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
                        </div>
                        <span class="sc-label">Inventory<br>Management</span>
                    </div>

                    <div class="sc-card sc-card--mid-left" style="--delay:-12s">
                        <div class="sc-icon" style="background:#fff0e8;">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                        </div>
                        <span class="sc-label">Point of<br>Sale</span>
                    </div>

                    <div class="sc-card sc-card--mid-left" style="--delay:-10.5s">
                        <div class="sc-icon" style="background:#fefce8;">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#eab308" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/><path d="M8 6h8M8 10h8M8 14h4"/></svg>
                        </div>
                        <span class="sc-label">IoT<br>Integrations</span>
                    </div>

                    <div class="sc-card sc-card--mid-left" style="--delay:-9s">
                        <div class="sc-icon" style="background:#f0f9ff;">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0ea5e9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
                        </div>
                        <span class="sc-label">Staff &amp;<br>Payroll</span>
                    </div>

                    <div class="sc-card sc-card--mid-left" style="--delay:-7.5s">
                        <div class="sc-icon" style="background:#fff1f2;">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#f43f5e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                        </div>
                        <span class="sc-label">GST &amp;<br>Tax Reports</span>
                    </div>

                    <div class="sc-card sc-card--mid-left" style="--delay:-6s">
                        <div class="sc-icon" style="background:#f0fdf4;">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                        </div>
                        <span class="sc-label">Payment<br>Modes</span>
                    </div>

                    <div class="sc-card sc-card--mid-left" style="--delay:-4.5s">
                        <div class="sc-icon" style="background:#eff6ff;">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                        </div>
                        <span class="sc-label">Daily Sales<br>Reports</span>
                    </div>

                    <div class="sc-card sc-card--mid-left" style="--delay:-3s">
                        <div class="sc-icon" style="background:#fdf2f8;">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#c026d3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                        </div>
                        <span class="sc-label">Customer<br>Feedback</span>
                    </div>

                    <div class="sc-card sc-card--mid-left" style="--delay:-1.5s">
                        <div class="sc-icon" style="background:#f7fee7;">
                            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#65a30d" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                        </div>
                        <span class="sc-label">Table<br>Management</span>
                    </div>

                </div>
            </div>

            <!-- Feature carousel tabs -->
            <div class="pf-tabs">
                <button class="pf-tab pf-tab--active" data-tab="kitchen" type="button">Kitchen Display</button>
                <button class="pf-tab" data-tab="voice" type="button">Voice Ordering</button>
            </div>

            <!-- Feature panel: Kitchen Display -->
            <div class="pf-panel pf-panel--active" id="pf-kitchen">
                <div class="pf-panel-inner">
                    <div class="pf-desc-card">
                        <h3 class="pf-card-title">Kitchen Display Integration</h3>
                        <p class="pf-card-body">Orders will appear at the correct station with colour-coded priority and prep timers — help us refine the flow during pilot runs.</p>
                        <div class="pf-nav-arrows">
                            <button class="pf-arrow" type="button" aria-label="Previous feature" data-dir="-1">
                                <img src="/images/icon-arrow-prev.svg" alt="Previous" width="70" height="70">
                            </button>
                            <button class="pf-arrow" type="button" aria-label="Next feature" data-dir="1">
                                <img src="/images/icon-arrow-next.svg" alt="Next" width="70" height="70">
                            </button>
                        </div>
                    </div>
                    <div class="pf-feature-img-wrap pf-feature-img-wrap--blue">
                        <img src="/images/illus-kitchen.png"
                             alt="Kitchen display integration view"
                             class="pf-feature-img"
                             loading="lazy">
                    </div>
                </div>
            </div>

            <!-- Feature panel: Voice Ordering -->
            <div class="pf-panel" id="pf-voice">
                <div class="pf-panel-inner">
                    <div class="pf-desc-card">
                        <h3 class="pf-card-title">Natural Language Understanding</h3>
                        <p class="pf-card-body">Natural language ordering with multilingual support and smart upsells.</p>
                        <div class="pf-nav-arrows">
                            <button class="pf-arrow" type="button" aria-label="Previous feature" data-dir="-1">
                                <img src="/images/icon-arrow-prev.svg" alt="Previous" width="70" height="70">
                            </button>
                            <button class="pf-arrow" type="button" aria-label="Next feature" data-dir="1">
                                <img src="/images/icon-arrow-next.svg" alt="Next" width="70" height="70">
                            </button>
                        </div>
                    </div>
                    <div class="pf-feature-img-wrap pf-feature-img-wrap--blue">
                        <img src="/images/illus-voice.png"
                             alt="Voice ordering microphone interface"
                             class="pf-feature-img pf-feature-img--mic"
                             loading="lazy">
                    </div>
                </div>
            </div>
        </section>

        <!-- ===== TIMELINE: HOW IT WORKS ===== -->
        <section class="timeline-section" id="how-it-works">
            <div class="container">
                <div class="tl-header">
                    <span class="fig-badge">How It Works</span>
                    <h2 class="fig-heading-2"><span style="color:#4b33ff;">Three</span> Steps to Smarter Service</h2>
                    <p class="fig-subheading">From order to insight in seconds. Here's how Bhojan Mitra transforms your restaurant operations.</p>
                </div>

                <div class="tl-steps">
                    <!-- Step 1 -->
                    <div class="tl-step">
                        <div class="tl-step-left">
                            <div class="tl-num-wrap">
                                <span class="tl-num">01</span>
                                <div class="tl-line"></div>
                            </div>
                            <div class="tl-text">
                                <h3 class="tl-title">Capture Orders</h3>
                                <p class="tl-desc">Customers order via voice, app, or your POS terminal. Every channel feeds into one system.</p>
                            </div>
                        </div>
                        <div class="tl-step-right">
                            <img src="/images/illus-pos-terminal.png"
                                 alt="iPad Mini POS terminal"
                                 class="tl-img"
                                 loading="lazy">
                        </div>
                    </div>

                    <!-- Step 2 -->
                    <div class="tl-step">
                        <div class="tl-step-left">
                            <div class="tl-num-wrap">
                                <span class="tl-num">02</span>
                                <div class="tl-line"></div>
                            </div>
                            <div class="tl-text">
                                <h3 class="tl-title">Processing &amp; Insights</h3>
                                <p class="tl-desc">Our AI validates orders, suggests upsells, and routes to the kitchen — all in milliseconds.</p>
                            </div>
                        </div>
                        <div class="tl-step-right">
                            <img src="/images/illus-ai.png"
                                 alt="AI processing illustration"
                                 class="tl-img"
                                 loading="lazy">
                        </div>
                    </div>

                    <!-- Step 3 -->
                    <div class="tl-step tl-step--last">
                        <div class="tl-step-left">
                            <div class="tl-num-wrap">
                                <span class="tl-num">03</span>
                            </div>
                            <div class="tl-text">
                                <h3 class="tl-title">Service, Higher Insights</h3>
                                <p class="tl-desc">Our AI validates orders, suggests upsell, and routes to the kitchen — all in milliseconds.</p>
                            </div>
                        </div>
                        <div class="tl-step-right">
                            <img src="/images/illus-analytics.png"
                                 alt="Customer insight dashboard"
                                 class="tl-img"
                                 loading="lazy">
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ===== HELP US SHAPE ===== -->
        <section class="help-shape" id="why-us">
            <div class="container">
                <div class="hs-badge-wrap">
                    <span class="fig-badge">Pilot Program Perks</span>
                </div>
                <div class="hs-grid">
                    <!-- Left: Text + CTA -->
                    <div class="hs-left">
                        <h2 class="hs-title">Help Us Shape <span class="fig-muted">Bhojan Mitra</span> From Day Zero</h2>
                        <p class="hs-desc">We're opening a small cohort of early adopters who want to co-build the ideal voice-led POS for their restaurant floor.</p>
                        <a href="/contact" class="btn-figma-primary">Join the Pilot</a>
                    </div>

                    <!-- Right: Perk cards -->
                    <div class="hs-right">
                        <div class="hs-perk-card">
                            <div class="hs-perk-icon">
                                <img src="/images/icon-perk-chat.svg" alt="" width="40" height="40" aria-hidden="true">
                            </div>
                            <div class="hs-perk-content">
                                <h4 class="hs-perk-title">Direct Product Access</h4>
                                <p class="hs-perk-desc">Work directly with the product and engineering team to request features that match your service model.</p>
                            </div>
                        </div>

                        <div class="hs-perk-card">
                            <div class="hs-perk-icon">
                                <img src="/images/icon-perk-gift.svg" alt="" width="40" height="40" aria-hidden="true">
                            </div>
                            <div class="hs-perk-content">
                                <h4 class="hs-perk-title">Hardware Credits</h4>
                                <p class="hs-perk-desc">Receive hardware credits and discounted pricing for life when we move from pilot to full release.</p>
                            </div>
                        </div>

                        <div class="hs-perk-card">
                            <div class="hs-perk-icon">
                                <img src="/images/icon-perk-rocket.svg" alt="" width="40" height="40" aria-hidden="true">
                            </div>
                            <div class="hs-perk-content">
                                <h4 class="hs-perk-title">Launch Support</h4>
                                <p class="hs-perk-desc">On-site or remote launch support, staff training, and playbooks tailored to your kitchen setup.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ===== PRICING ===== -->
