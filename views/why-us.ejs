<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head', { seo }) %>
</head>
<body>
  <%- include('partials/header') %>

  <main>

    <!-- ===== WHY BHOJAN MITRA ===== -->
    <section class="why-hero-section">
      <div class="container">
        <div class="why-hero-inner">
          <h1 class="why-hero-title">Why <span class="fig-gradient-text">Bhojan Mitra?</span></h1>
          <p class="why-hero-sub">Most POS systems fail restaurants when it matters most. They rely on manual inputs, rigid workflows, language limitations, and disconnected tools &mdash; leading to order errors, slow service, and poor visibility into what's really happening on the floor.</p>
        </div>

        <!-- YOUR PROBLEM -->
        <div class="why-badge-row">
          <span class="why-section-badge why-section-badge--problem">YOUR PROBLEM</span>
        </div>
        <div class="why-problems-grid">
          <div class="why-problem-pill">
            <span>&#128562;</span> Long Ques
          </div>
          <div class="why-problem-pill">
            <span>&#127760;</span> Lost in Translation
          </div>
          <div class="why-problem-pill">
            <span>&#128544;</span> Frustrated Staff
          </div>
          <div class="why-problem-pill">
            <span>&#128293;</span> Kitchen Chaos
          </div>
          <div class="why-problem-pill">
            <span>&#128065;</span> No visibility
          </div>
          <div class="why-problem-pill">
            <span>&#128203;</span> Manual Errors
          </div>
        </div>

        <!-- OUR SOLUTION -->
        <div class="why-badge-row why-badge-row--solution">
          <span class="why-section-badge why-section-badge--solution">OUR SOLUTION</span>
        </div>
      </div>
    </section>

    <!-- ===== SOLUTION HUB ===== -->
    <section class="why-solution-section">
      <div class="container">
        <div class="why-solution-header">
          <h2 class="why-solution-title">Every Restaurant Moment Gets Easier With Bhojan Mitra</h2>
          <p class="why-solution-sub">Most POS systems fail restaurants when it matters most. They rely on manual inputs, rigid workflows, language limitations, and disconnected tools &mdash; leading to order errors, slow service, and poor visibility into what's really happening on the floor.</p>
        </div>

        <!-- Hub diagram -->
        <div class="why-hub-grid">

          <!-- Top-left -->
          <div class="why-hub-card why-hub-card--tl" style="--card-color:#f869c6;--card-bg:rgba(248,105,198,0.07)">
            <div class="why-hub-card-icon-box" style="background:rgba(248,105,198,0.12)">
              <img src="/images/illus-kitchen.png" alt="IoT integrated" width="40" height="40">
            </div>
            <h3>IoT Integrated</h3>
            <p>Connected devices that sync orders instantly across kitchen, billing, and floor.</p>
          </div>

          <!-- Top-right -->
          <div class="why-hub-card why-hub-card--tr" style="--card-color:#6366f1;--card-bg:rgba(99,102,241,0.07)">
            <div class="why-hub-card-icon-box" style="background:rgba(99,102,241,0.12)">
              <img src="/images/illus-dashboard.png" alt="Table order" width="40" height="40">
            </div>
            <h3>Table Order &amp; Management</h3>
            <p>Real-time table status with smart order routing and floor visibility.</p>
          </div>

          <!-- Center hub -->
          <div class="why-hub-center-cell">
            <div class="why-hub-center-ring why-hub-center-ring--outer">
              <div class="why-hub-center-ring why-hub-center-ring--inner">
                <div class="why-hub-logo-circle">
                  <img src="/images/logo.png" alt="Aarohita Vigyan" width="52" height="52">
                  <span>Aarohita<br>Vigyan</span>
                </div>
              </div>
            </div>
            <!-- spoke lines -->
            <div class="why-hub-spoke why-hub-spoke--tl"></div>
            <div class="why-hub-spoke why-hub-spoke--tr"></div>
            <div class="why-hub-spoke why-hub-spoke--l"></div>
            <div class="why-hub-spoke why-hub-spoke--r"></div>
            <div class="why-hub-spoke why-hub-spoke--b"></div>
          </div>

          <!-- Left -->
          <div class="why-hub-card why-hub-card--l" style="--card-color:#10b981;--card-bg:rgba(16,185,129,0.07)">
            <div class="why-hub-card-icon-box" style="background:rgba(16,185,129,0.12)">
              <img src="/images/illus-voice.png" alt="Voice ordering" width="40" height="40">
            </div>
            <h3>Voice Ordering</h3>
            <p>Take orders naturally in any language with AI-powered voice recognition.</p>
          </div>

          <!-- Right -->
          <div class="why-hub-card why-hub-card--r" style="--card-color:#f59e0b;--card-bg:rgba(245,158,11,0.07)">
            <div class="why-hub-card-icon-box" style="background:rgba(245,158,11,0.12)">
              <img src="/images/illus-analytics.png" alt="Inventory" width="40" height="40">
            </div>
            <h3>Inventory Management</h3>
            <p>Track stock in real-time and get low-stock alerts before service starts.</p>
          </div>

          <!-- Bottom-center -->
          <div class="why-hub-card why-hub-card--b" style="--card-color:#ef4444;--card-bg:rgba(239,68,68,0.07)">
            <div class="why-hub-card-icon-box" style="background:rgba(239,68,68,0.12)">
              <img src="/images/illus-pos-terminal.png" alt="Billing" width="40" height="40">
            </div>
            <h3>Billing &amp; Invoice</h3>
            <p>Fast GST-ready checkout with digital invoices sent to any customer instantly.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="cta-home">
      <div class="container">
        <div class="cta-home-inner">
          <h2 class="cta-home-title">See Bhojan Mitra <span class="fig-gradient-text">in Action</span></h2>
          <p class="cta-home-desc">Join the pilot to experience voice ordering, IoT routing, and analytics tailored to your restaurant before our public launch.</p>
          <a href="/contact" class="btn-figma-primary">Get Started</a>
        </div>
      </div>
    </section>

  </main>

  <%- include('partials/footer') %>
  <script src="/js/main.js?v=<%= locals.assetVersion %>"></script>
</body>
</html>
